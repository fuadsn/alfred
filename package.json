{
  "name": "debrief",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "npm run build:styles",
    "dev": "npm run dev:styles & npm run dev:server & npm run dev:client",
    "dev:client": "vite --config client/vite.config.js",
    "dev:server": "node --env-file-if-exists=.env --watch server/index.js",
    "dev:styles": "tailwindcss -c client/tailwind.config.js -i client/src/styles.input.css -o client/src/styles.css --watch",
    "build": "npm run build:styles && npm run build:client",
    "build:client": "vite build --config client/vite.config.js",
    "build:styles": "tailwindcss -c client/tailwind.config.js -i client/src/styles.input.css -o client/src/styles.css --minify",
    "start": "node --env-file-if-exists=.env server/index.js"
  },
  "dependencies": {
    "express": "^5.1.0",
    "multer": "^2.0.2",
    "openai": "^5.10.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.17",
    "vite": "^7.1.2"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
